# ---- MATLAB ----
*.asv          # autosave files
*.m~           # backup files from some editors
*.mex*         # compiled MEX binaries (platform-specific)
*.mlappinstall
*.mltbx
slprj/
sccprj/
codegen/
*.autosave

# MATLAB Simulink (not currently used, but harmless to exclude)
*.slxc
