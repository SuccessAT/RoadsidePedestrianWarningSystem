data/*.mat
data/*.csv
*.mat
!config/*.mat        # uncomment/adjust if you ever store reference configs as .mat
*.avi
*.mp4
*.gif

# ---- OS junk ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor/IDE ----
.vscode/
*.swp
*~

